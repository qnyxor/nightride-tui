# Enforce LF line endings and UTF-8 across the repository.
* text=auto eol=lf

# Explicit text types.
*.rs        text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
Makefile    text eol=lf

# Treat lockfile and license text as plain text (LF) too.
Cargo.lock  text eol=lf
LICENSES/*  text eol=lf
